{
  "name": "@remitmd/mcp-server",
  "version": "0.2.1",
  "description": "MCP server for remit.md - enables any MCP-compatible AI agent to make and receive payments",
  "type": "module",
  "bin": {
    "remitmd-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import=./node_modules/tsx/dist/esm/index.cjs --test tests/*.ts",
    "test:acceptance": "node --import=./node_modules/tsx/dist/esm/index.cjs --test tests/acceptance/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --lines 60 --functions 60 --branches 60 node --import=./node_modules/tsx/dist/esm/index.cjs --test tests/*.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@remitmd/sdk": "^0.1.7",
    "viem": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
